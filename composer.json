{
    "name": "aistea/aistea-seo",
    "type": "typo3-cms-extension",
    "description": "Aistea SEO Crawler for TYPO3 - crawls external websites and generates SEO audit reports",
    "homepage": "https://aistea.me",
    "license": ["GPL-2.0-or-later"],
    "keywords": ["TYPO3 CMS", "SEO", "SEO Spider", "audit", "reports"],
    "require": {
        "typo3/cms-core": "^14.0",
        "typo3/cms-extbase": "^14.0",
        "typo3/cms-fluid": "^14.0",
        "typo3/cms-backend": "^14.0"
    },
    "autoload": {
        "psr-4": {
            "Aistea\\AisteaSeo\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "aistea_seo"
        }
    }
}
